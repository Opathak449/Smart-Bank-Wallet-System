# ============================================================
# SmartBank Wallet - Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# ──────────────────────────────────────────────
# BACKEND (Railway environment variables)
# ──────────────────────────────────────────────

# Database (Railway provides DATABASE_URL automatically if you add a Postgres plugin)
DB_USERNAME=postgres
DB_PASSWORD=YourStrongPassword123!
# Railway PostgreSQL URL format: postgresql://user:password@host:port/dbname
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartbank_db

# JWT - Use a long random string (min 64 chars)
JWT_SECRET=SmartBankSuperSecretKeyForJWTTokenGenerationAndValidation2024ChangeThis

# Email (Gmail example — create an App Password at myaccount.google.com/apppasswords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# CORS — set to your Vercel frontend URL after deploying
CORS_ORIGINS=https://your-app.vercel.app

# Upload directory
UPLOAD_DIR=./uploads

# ──────────────────────────────────────────────
# FRONTEND (Vercel environment variables)
# ──────────────────────────────────────────────

# Set this in Vercel dashboard → Project Settings → Environment Variables
# Point to your Railway backend URL, e.g.:
REACT_APP_API_URL=https://your-backend.railway.app/api
